{
  "name": "plan_send_check",
  "dependencies": {
    "nodemailer": "^6.10.1",
    "uni-config-center": "file:../common/uni-config-center"
  },
  "extensions": {
    "uni-cloud-jql": {},
    "uni-cloud-sms": {}
  },
  "cloudfunction-config": {
    "triggers": [
      {
        "name": "timer_plan_send_check",
        "type": "timer",
        "config": "0 0 0 */1 * * *"
      }
    ],
    "timeout": 60
  }
}